# ─── NexusAI Digest — Environment Configuration Template ──────────────────────
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL (Neon or any Postgres):
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# SQLite (local development only):
# DATABASE_URL="sqlite+aiosqlite:///./database.db"

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(48))"
JWT_SECRET="CHANGE_ME_REPLACE_WITH_96_CHAR_HEX_STRING"

# ─── Admin Access ─────────────────────────────────────────────────────────────
# Comma-separated list of email addresses that will be granted admin role
ADMIN_EMAILS="admin@yourdomain.com"

# ─── Owner / Branding ─────────────────────────────────────────────────────────
OWNER_NAME="Your Name"

# ─── Google OAuth (optional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/auth/google/callback"

# ─── Groq AI API ──────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY="gsk_YOUR_GROQ_API_KEY_HERE"
GROQ_API_URL="https://api.groq.com/openai/v1/chat/completions"

# ─── Resend Email API ─────────────────────────────────────────────────────────
# Get your key at: https://resend.com/api-keys
RESEND_API="re_YOUR_RESEND_API_KEY_HERE"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8000
# Set to your production frontend URL (e.g. https://yourdomain.com) in production
FRONTEND_URL="http://localhost:3000"
